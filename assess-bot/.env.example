# Copy to  assess-bot/.env  and fill in. NEVER commit the real .env (it's gitignored).
BOT_TOKEN=telegram-bot-token-from-botfather
SHODAN_API_KEY=your-shodan-key
ALLOWED_USERS=                       # blank = anyone who passes the zero-trust /auth gate

# Zero-trust access
COLT_BOT_PASSWORD=long-shared-access-secret
AUTH_MAX_FAILS=5
AUTH_LOCK_SECS=900

# 2FA email delivery — Gmail API (HTTPS, preferred; SMTP is blocked on the droplet)
REQUIRE_2FA=1
GMAIL_SENDER=name@yourdomain.com
GMAIL_SA_B64=                        # set via:  python enable_gmail_api.py service-account.json
OTP_TTL_SECS=600
OTP_MAX_TRIES=5
# SMTP fallback (local dev only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=1
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# DigitalOcean serverless inference (DeepSeek)
OPENAI_API_KEY=doo_v1_xxx
OPENAI_BASE_URL=https://inference.do-ai.run/v1
ENRICH_MODEL=deepseek-3.2
ENRICH_TIMEOUT=200
ENRICH_ATTEMPTS=1
QWEN_PRICE_PER_M=0.80

# --- AbuseIPDB (optional): submit scanning/brute-force IPs to the community feed ---
# Free key: https://www.abuseipdb.com/account/api
# Leave empty to detect + report to yourself only. NEVER commit a real key.
ABUSEIPDB_KEY=
ABUSEIPDB_SKIP_RESEARCH=1
