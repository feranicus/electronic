# Copy to  cassandra-bot/.env  and fill in. NEVER commit the real .env.
BOT_TOKEN=telegram-bot-token-from-botfather
ALLOWED_USERS=

COLT_BOT_PASSWORD=long-shared-access-secret
AUTH_MAX_FAILS=5
AUTH_LOCK_SECS=900

REQUIRE_2FA=1
GMAIL_SENDER=name@yourdomain.com
GMAIL_SA_B64=                        # set via:  python enable_gmail_api.py service-account.json
OTP_TTL_SECS=600
OTP_MAX_TRIES=5
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=1
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# DeepSeek chat + fast fallback
OPENAI_API_KEY=doo_v1_xxx
OPENAI_BASE_URL=https://inference.do-ai.run/v1
ASSIST_MODEL=deepseek-3.2
ASSIST_FALLBACK_MODEL=openai-gpt-oss-120b
ASSIST_TIMEOUT=60
ASSIST_MAX_TOKENS=1200

# live web research (Chromium fallback). 0 = HTTP-only (lighter on small droplets)
ENABLE_BROWSER=1
FETCH_MIN_DELAY=1.2
FETCH_MAX_DELAY=2.8
BROWSER_TIMEOUT=20000
