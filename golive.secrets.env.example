# ── golive one-time secrets ──────────────────────────────────────────────
# Copy this file to  golive.secrets.env  and fill it in ONCE. It is gitignored
# and never leaves your machine. golive.py reads it and hands the values to
# deploy.py / provision_web.py so the WHOLE thing (deploy + DNS + TLS) is automatic.
#
# GoDaddy API key (this is the ONE credential that lets a script change your DNS):
#   get it at  https://developer.godaddy.com/keys  ->  "Create New API Key" ->
#   Environment = Production  ->  copy the Key and Secret below.
GODADDY_API_KEY=
GODADDY_API_SECRET=
#
# Droplet (defaults are already correct — only change if yours differs):
DROPLET_HOST=64.225.108.200
DROPLET_USER=root
# Path to the SSH private key that logs into the droplet (leave blank to use your ssh-agent/default):
SSH_KEY=
#
# Optional: DigitalOcean token (only used if you ever move DNS to DO instead of GoDaddy):
DO_API_TOKEN=
