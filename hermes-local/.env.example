# ===================================================================
#  Hermes local — secrets & endpoints.  Copy to  .env  and fill in.
#  docker compose reads this file automatically.  Never commit .env.
# ===================================================================

# --- Model: your DigitalOcean Qwen (OpenAI-compatible) ---
OPENAI_API_KEY=doo_v1_PUT_YOUR_DO_QWEN_KEY_HERE
OPENAI_BASE_URL=https://inference.do-ai.run/v1

# --- Shodan: THIS is where you paste your Shodan API key ---
SHODAN_API_KEY=PUT_YOUR_SHODAN_KEY_HERE

# --- Telegram bot token ---
# Only needed if it's NOT already saved in the hermes_data volume from your
# earlier `hermes gateway setup`. If the bot already worked, leave this commented.
# TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token...
