# DigitalOcean Serverless Inference (OpenAI-compatible)
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1
DO_INFERENCE_KEY=doo_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# leave empty to auto-pick the first model returned by /api/models, or set an exact id
QWEN_MODEL=
DATA_DIR=/data
CORS_ORIGINS=*

# ---- LLM-driven agent proxy (the local jhw-agent authenticates with this, NOT the DO key) ----
# Shared token the /v1 proxy checks. Generate a random string; give it to each candidate's agent.
AGENT_PROXY_TOKEN=change-me

# ---- Per-role model routing (optional overrides; defaults live in backend/app/llm.py) ----
# JHW_MODEL_DRIVER=anthropic-claude-4.6-sonnet
# JHW_MODEL_VISION=nemotron-nano-12b-v2-vl
# JHW_MODEL_CONTENT=deepseek-3.2
# JHW_MODEL_EXTRACT=llama3.3-70b-instruct
# JHW_MODEL_CHAT=deepseek-3.2
