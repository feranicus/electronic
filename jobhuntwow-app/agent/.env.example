# jhw-agent config — copy to .env. NO DO key here; the droplet /v1 proxy holds it.
JHW_PROXY_BASE=http://host.docker.internal:8000/v1
AGENT_PROXY_TOKEN=change-me
LINKEDIN_COOKIES=/agent/linkedin_cookies.json
JHW_CDP_URL=http://localhost:9222
JHW_ASK_CHANNEL=auto
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
JHW_ASK_TIMEOUT=600

# ---- Auto-login (OPTIONAL). Preferred: log in once in noVNC — the profile now persists. ----
# If you want the agent to re-login when the session expires, PREFER a LinkedIn-native password
# (LinkedIn > Settings > Sign in & security > set password). Scoped to LinkedIn, rotatable.
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
# Google is your MASTER account + Google blocks automated logins (CAPTCHA/2FA). Use only if you must.
GOOGLE_EMAIL=
GOOGLE_PASSWORD=
