# jhw-agent config — copy to .env (gitignored). NO DO key here; the droplet proxy holds it.

# Where the OpenAI-compatible proxy lives. Local backend: http://localhost:8000/v1
# Production (droplet): https://app.jobhuntwow.com/v1
JHW_PROXY_BASE=http://localhost:8000/v1

# Per-candidate token that the proxy checks (must match AGENT_PROXY_TOKEN on the backend).
AGENT_PROXY_TOKEN=change-me

# Candidate's exported LinkedIn session.
LINKEDIN_COOKIES=linkedin_cookies.json

# Chromium headless? Headed (false) lets you watch + solve any checkpoint (WSLg shows the window).
HEADLESS=false
