    {
      "type": "logs",
      "title": "Live event stream (run_id \u00b7 evt \u00b7 phase \u00b7 state)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{bot=\"patchwatch\"} | json | line_format \"{{.run_id}}  {{.evt}} {{.phase}} {{.state}} {{if .dur_s}}({{.dur_s}}s){{end}} {{.err}}\"",
          "editorMode": "code",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "type": "bargauge",
      "title": "Phase durations \u2014 most recent run",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (phase) (last_over_time({bot=\"patchwatch\"} | json | evt=\"phase\" | state=\"done\" | unwrap dur_s [30d]))",
          "editorMode": "code",
          "queryType": "instant"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
