# /etc/patchwatch/patchwatch.env  — fill this on the DROPLET only. NEVER commit real values.
# (Shared DeepSeek/Telegram secrets can instead live in /opt/colt-stack/.env, which the
#  service also loads. Anything set here overrides those.)

# ---- behaviour ----
UPGRADE_MODE=full           # 'full' = upgrade everything (your choice) | 'security' = security only
REBOOT_MODE=auto            # 'auto' = reboot in the window if a kernel update needs it | 'notify'
REQUIRE_BACKUP=1            # 1 = ABORT the upgrade if the backup fails (recommended)
PATCHWATCH_DRY_RUN=0        # 1 = inventory + would-be actions, change nothing (use for the first test)

# ---- DigitalOcean Spaces (S3-compatible) backup target — REQUIRED ----
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
SPACES_REGION=fra1
SPACES_BUCKET=your-space-name
SPACES_PREFIX=patchwatch
SPACES_KEY=your-spaces-access-key
SPACES_SECRET=your-spaces-secret-key
BACKUP_KEEP=6              # keep the last N backups in Spaces

# ---- Optional: full droplet snapshot via the DO API (belt & suspenders) ----
# Create a token at cloud.digitalocean.com > API. DROPLET_ID is the numeric id of this droplet.
DO_API_TOKEN=
DROPLET_ID=
SNAPSHOT_KEEP=3

# ---- What to back up (paths that exist on the droplet) ----
BACKUP_PATHS=/etc /opt/colt-stack /root/colt-stack
COMPOSE_PROJECT=colt-stack

# ---- LLM digest (reuse your DO serverless inference) ----
OPENAI_API_KEY=            # if not set here, inherited from /opt/colt-stack/.env
OPENAI_BASE_URL=https://inference.do-ai.run/v1
PATCH_LLM_MODEL=deepseek-3.2

# ---- Telegram digest ----
PATCH_TG_TOKEN=           # a bot token (can reuse colttechbot's); if blank, falls back to BOT_TOKEN
PATCH_TG_CHAT=            # YOUR numeric Telegram chat id (message @userinfobot to get it)

# ---- where to append JSON events for promtail -> Loki -> Grafana ----
PATCH_EVENTS_LOG=/opt/colt-stack/observe/events.log
